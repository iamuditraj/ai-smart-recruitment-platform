# ============================================================
# BACKEND ENVIRONMENT VARIABLES
# ============================================================
# 
# SETUP INSTRUCTIONS (for new team members):
#   1. Copy this file:  cp .env.example .env
#   2. Fill in the values below (ask the team lead for keys)
#   3. NEVER commit the .env file — it is gitignored for security
#
# You also need "serviceAccountKey.json" in this folder:
#   → Go to Firebase Console → Project Settings → Service Accounts
#   → Click "Generate New Private Key" → Save as serviceAccountKey.json
# ============================================================

# Flask Configuration
FLASK_APP=app.py
FLASK_ENV=development
PORT=5001

# Firebase Configuration
# Path to your Firebase service account key file (should be in this folder)
FIREBASE_SERVICE_ACCOUNT_KEY=serviceAccountKey.json

# AI Configuration
# Get this key from the team lead or generate one at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
