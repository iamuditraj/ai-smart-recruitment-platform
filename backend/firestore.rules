rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Fast login lookup — readable by anyone, never written from client
    match /user_index/{email} {
      allow read: if true;
      allow write: if false;
    }

    // Candidate profiles and their resume subcollection
    match /candidates/{email} {
      allow read, write: if true;
      match /resumes/{resumeId} {
        allow read, write: if true;
      }
    }

    // Recruiter profiles
    match /recruiters/{email} {
      allow read, write: if true;
    }

    // Jobs and their applications subcollection
    match /jobs/{jobId} {
      allow read: if true;
      allow write: if true;
      match /applications/{appId} {
        allow read, write: if true;
      }
    }
  }
}
