rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Profiles and mappings: accessible only by the owner
    match /user_index/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false; // Backend only
    }

    match /candidates/{uid} {
      function isCollegeAdmin() {
        return request.auth.token.role == 'college' &&
               request.auth.token.tenant_id in resource.data.college_ids;
      }
      function isRecruiter() {
        return request.auth.token.role == 'recruiter' &&
               request.auth.token.tenant_id in resource.data.recruiter_ids;
      }

      allow read: if request.auth != null && (
        request.auth.uid == uid || isCollegeAdmin() || isRecruiter()
      );
      allow write: if false; // Backend only
      
      match /resumes/{resumeId} {
        function isParentCollegeAdmin() {
          return request.auth.token.role == 'college' &&
                 request.auth.token.tenant_id in get(/databases/$(database)/documents/candidates/$(uid)).data.college_ids;
        }
        function isParentRecruiter() {
          return request.auth.token.role == 'recruiter' &&
                 request.auth.token.tenant_id in get(/databases/$(database)/documents/candidates/$(uid)).data.recruiter_ids;
        }

        allow read: if request.auth != null && (
          request.auth.uid == uid || isParentCollegeAdmin() || isParentRecruiter()
        );
        allow write: if false; // Backend only
      }
    }

    match /recruiters/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false; // Backend only
    }

    match /colleges/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false; // Backend only
    }

    match /companies/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false; // Backend only
    }

    // Backend-managed collections
    match /jobs/{jobId} {
      function isActiveJob() {
        return resource.data.status == 'active';
      }
      function isJobOwner() {
        return request.auth.token.company_id == resource.data.company_id || 
               request.auth.token.college_id == resource.data.college_id;
      }

      allow read: if request.auth != null && (
        isActiveJob() || isJobOwner()
      );
      allow write: if false; // Backend only
      
      match /applications/{appId} {
        allow read, write: if false;
      }
    }
  }
}
